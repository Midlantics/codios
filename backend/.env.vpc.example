# ── Codios VPC — environment variables ───────────────────────────────────────
# Copy to .env and fill in the values.
# Generate keys by running: ./setup-vpc.sh --keys-only

# Database
POSTGRES_PASSWORD=change-me-strong-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# Ed25519 platform signing keys (generated by setup-vpc.sh)
CODIOS_PRIVATE_KEY=
CODIOS_PUBLIC_KEY=
CODIOS_DID=

# JWT secret — any long random string (used to sign API session tokens)
JWT_SECRET=change-me-jwt-secret-min-32-chars

# Internal gateway secret (shared between services)
GATEWAY_SECRET=change-me-gateway-secret

# Deployment
PORT=8080
APP_URL=https://codios.your-domain.com
ALLOWED_ORIGINS=https://codios.your-domain.com

# Email alerts (choose one: Resend or SMTP)
RESEND_API_KEY=
RESEND_FROM=Codios Alerts <alerts@your-domain.com>

# SMTP fallback (if RESEND_API_KEY is blank, SMTP is used)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
